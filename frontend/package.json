{
  "name": "perfume-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "next lint",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "start": "next start",
    "perf:lhci": "lhci autorun --config=./lighthouserc.json",
    "perf:audit": "npm run build && npm run perf:lhci"
  },
  "dependencies": {
    "axios": "^1.15.0",
    "debug": "^4.4.3",
    "next": "15.5.15",
    "leaflet": "^1.9.4",
    "next-themes": "^0.4.6",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "supports-color": "^8.1.1"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.40.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "15.5.15",
    "playwright": "^1.40.0"
  },
  "overrides": {
    "follow-redirects": "1.16.0"
  }
}
