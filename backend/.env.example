### Example .env for local development
# Copy this file to `.env` and fill real secrets. Do NOT commit real secrets.

# JWT secret used to sign tokens. Must be at least 32 characters and
# must NOT contain the substring "dev_secret" (checked by the app).
JWT_KEY=your-very-strong-secret-with-32+chars-or-more-REPLACE_ME

# Optional: force/sync a known admin credential on startup.
# Useful for first deploys or recovering access in production.
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=change-me-to-a-strong-password

# Render/containers typically inject PORT dynamically. The Docker entrypoint
# binds ASPNETCORE_URLS using this value.
PORT=8080

# SQLite connection (optional). Defaults to Data Source=AppData/perfume.db
# Example for a file-based DB in project root:
ConnectionStrings__Default=Data Source=AppData/perfume.db

# Redis connection (optional). If you don't use Redis leave empty.
REDIS_CONNECTION=redis://localhost:6379

# ASP.NET Core URL (optional for `dotnet run` override)
ASPNETCORE_URLS=http://localhost:5001

# Other envs you might set in development:
# - Logging__LogLevel__Default=Information
# - DOTNET_ENVIRONMENT=Development

# ZATCA (Saudi e-invoicing) integration - phase 1 foundation
# Keep disabled until full certificate/signing + API compliance is completed.
Zatca__Enabled=false
Zatca__Environment=sandbox
Zatca__BaseUrl=
Zatca__SubmitPath=/simulation/invoices
Zatca__HttpTimeoutSeconds=30
Zatca__DeviceId=
Zatca__SolutionName=PerfumeEmpire
Zatca__ApiSecret=
Zatca__CertificatePem=
Zatca__PrivateKeyPem=

# ------------------------------------------------------------
# ZATCA Sandbox quick template (copy these values into `.env`)
# ------------------------------------------------------------
# 1) Set Enabled=true only after filling all required values.
# 2) Keep SubmitPath unless your ZATCA sandbox account requires another path.
# 3) For PEM values, store as a single line with \n (escaped new lines).
#
# Example:
# Zatca__CertificatePem=-----BEGIN CERTIFICATE-----\nMIIC...\n-----END CERTIFICATE-----
# Zatca__PrivateKeyPem=-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----
#
# Zatca__Enabled=true
# Zatca__Environment=sandbox
# Zatca__BaseUrl=https://YOUR-ZATCA-SANDBOX-BASE-URL
# Zatca__SubmitPath=/simulation/invoices
# Zatca__HttpTimeoutSeconds=30
# Zatca__DeviceId=YOUR_DEVICE_ID
# Zatca__SolutionName=PerfumeEmpire
# Zatca__ApiSecret=YOUR_SANDBOX_API_SECRET
# Zatca__CertificatePem=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
# Zatca__PrivateKeyPem=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
